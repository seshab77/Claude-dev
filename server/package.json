{
  "name": "@nimbus/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "predev": "npm run build --workspace=@nimbus/shared",
    "dev": "tsx watch src/index.ts",
    "prebuild": "npm run build --workspace=@nimbus/shared",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "pretypecheck": "npm run build --workspace=@nimbus/shared",
    "typecheck": "tsc --noEmit -p tsconfig.json"
  },
  "dependencies": {
    "@nimbus/shared": "*",
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.14.11",
    "tsx": "^4.19.0",
    "typescript": "^5.5.4"
  }
}
