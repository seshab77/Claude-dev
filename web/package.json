{
  "name": "@nimbus/web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "predev": "npm run build --workspace=@nimbus/shared",
    "dev": "vite",
    "prebuild": "npm run build --workspace=@nimbus/shared",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
